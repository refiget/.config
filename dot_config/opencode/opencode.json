{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {},
    "plan": {}
  },
  "autoupdate": true,
  "mcp": {
    "brave": {
      "command": [
        "npx",
        "-y",
        "@brave/brave-search-mcp-server",
        "--transport",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "timeout": 120000,
      "type": "local"
    },
  },
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "external_directory": "allow",
    "webfetch": "allow"
  },
  "plugin": [
    "opencode-kimi-full",
    "{env:HOME}/.config/opencode/plugins/opencode-tmux-bridge"
  ],
  "provider": {
    "kimi-for-coding-oauth": {
      "models": {
        "kimi-for-coding": {
          "name": "Kimi For Coding",
          "reasoning": true,
          "variants": {
            "auto": {
              "reasoning_effort": "auto"
            },
            "high": {
              "reasoning_effort": "high"
            },
            "low": {
              "reasoning_effort": "low"
            },
            "medium": {
              "reasoning_effort": "medium"
            },
            "off": {
              "reasoning_effort": "off"
            }
          }
        }
      },
      "name": "Kimi For Coding (OAuth)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1"
      }
    },
    "moonshotai-cn": {
      "models": {
        "kimi-k2-thinking": {},
        "kimi-k2-turbo-preview": {},
        "kimi-k2.5": {}
      }
    },
    "n1n_relay": {
      "models": {
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5"
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        }
      },
      "name": "N1N Relay",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:N1N_RELAY_API_KEY}",
        "baseURL": "{env:N1N_RELAY_BASE_URL}/v1"
      }
    }
  }
}
