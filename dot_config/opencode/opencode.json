{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow",
    "external_directory": "allow",
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.3-codex"
    },
    "build": {
      "model": "openai/gpt-5.3-codex"
    }
  },
  "provider": {
    "n1n_relay": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "N1N Relay",
      "options": {
        "baseURL": "{env:N1N_RELAY_BASE_URL}/v1",
        "apiKey": "{env:N1N_RELAY_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5"
        }
      }
    },
    "moonshotai-cn": {
      "models": {
        "kimi-k2.5": {},
        "kimi-k2-thinking": {},
        "kimi-k2-turbo-preview": {}
      }
    }
  }
}
