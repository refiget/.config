{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "small_model": "moonshotai-cn/kimi-k2-turbo-preview",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  },
  "provider": {
    "yinli_relay": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Yinli Relay",
      "options": {
        "baseURL": "{env:YINLI_RELAY_BASE_URL}",
        "apiKey": "{env:YINLI_RELAY_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-5-20250929": {
          "name": "Claude Sonnet 4.5"
        },
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5"
        }
      }
    },
    "moonshotai-cn": {
      "models": {
        "kimi-k2.5": {},
        "kimi-k2-thinking": {},
        "kimi-k2-turbo-preview": {}
      }
    }
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.4"
    },
    "build": {
      "model": "openai/gpt-5.3-codex"
    }
  }
}
